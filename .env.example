# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=1

# SQL Server container (docker compose)
# Mật khẩu SA: tối thiểu 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# SQL Server connection (web app)
# Local: DB_SERVER=localhost | Docker: DB_SERVER=sqlserver (được ghi đè trong docker-compose)
DB_SERVER=localhost
DB_NAME=BankingTransactionDB
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=yes
